        </mxCell>
        <mxCell id="tHM4IbSP8WO20jyQorYi-182" value="You take the primary key from the parent entity and put it as foreign key in the child entity." style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#143642;fontSize=14;fontStyle=1" vertex="1" parent="1">
