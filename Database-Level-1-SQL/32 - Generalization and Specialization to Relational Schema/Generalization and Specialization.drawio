        <mxCell id="tHM4IbSP8WO20jyQorYi-180" value="To convert Generalization and Specialization into Relational Schema:" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#143642;fontSize=14;fontStyle=1" vertex="1" parent="1">
