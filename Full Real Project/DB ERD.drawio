        <mxCell id="LGPMdARM9gk4uqk6j2_b-7" value="2- person applies for a service" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=#82b366;fillColor=#d5e8d4;fontStyle=1" parent="1" vertex="1">
