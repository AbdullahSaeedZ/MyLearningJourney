        </mxCell>
        <mxCell id="LGPMdARM9gk4uqk6j2_b-9" value="4- if applied for local license then proceed to appointments" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=#82b366;fillColor=#d5e8d4;fontStyle=1" parent="1" vertex="1">
          <mxGeometry x="2090" y="-100" width="330" height="30" as="geometry" />
        </mxCell>
        <mxCell id="LGPMdARM9gk4uqk6j2_b-10" value="5- appointment is booked (3 tests per application) and can retake failed tests&lt;br&gt;if retake test, then new retakeApplication then new appointment record, but same local license application.&amp;nbsp;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=#82b366;fillColor=#d5e8d4;fontStyle=1" parent="1" vertex="1">
          <mxGeometry x="2440" y="-110" width="590" height="40" as="geometry" />
        </mxCell>
        <mxCell id="LGPMdARM9gk4uqk6j2_b-11" value="6- when applicant comes for test, it is conducted offline then user register test result and info" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=#82b366;fillColor=#d5e8d4;fontStyle=1" parent="1" vertex="1">
